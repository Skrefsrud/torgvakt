{
  "manifest_version": 3,
  "name": "Torgvakt: prishistorikk for FINN.no",
  "version": "0.1.0",
  "description": "Følg pris på FINN-annonser. Prishistorikk, prisfall-varsler og oversikt over annonsene du følger.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://www.finn.no/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.finn.no/recommerce/forsale/item/*",
        "https://www.finn.no/mobility/item/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Torgvakt" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
