{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "types": ["chrome", "vitest/globals", "node"],
    "skipLibCheck": true
  },
  "include": ["src", "tests", "e2e"]
}
